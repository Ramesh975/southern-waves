NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/southern_waves
JWT_SECRET=replace-with-a-unique-secret-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-secret-of-at-least-32-characters
ALLOWED_ORIGINS=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Optional email delivery
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=username
# SMTP_PASS=password
# FROM_NAME=Southern Waves
# FROM_EMAIL=no-reply@example.com

# Optional media storage (required for production uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
