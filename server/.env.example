PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/southern_waves?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d
NODE_ENV=production

# URLs and CORS (comma-separated list for allowed origins)
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=https://your-client-domain.vercel.app,http://localhost:5173

# Cloudinary Credentials (optional for local development fallback, required for cloud storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Mailer Settings (e.g., Mailtrap, SendGrid, Gmail, etc.)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
FROM_NAME=Southern Waves
FROM_EMAIL=no-reply@southernwaves.com